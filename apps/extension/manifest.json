{
  "manifest_version": 3,
  "name": "Favors",
  "version": "0.1.0",
  "description": "Save the current page to the local Favors library.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8123/*", "http://localhost:8123/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Save to Favors",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
