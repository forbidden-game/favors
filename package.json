{
  "name": "favors",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev:server": "cargo run --manifest-path apps/daemon/Cargo.toml",
    "dev:web": "npm --workspace @favors/web run dev",
    "build": "npm --workspace @favors/web run build && cargo build --release --manifest-path apps/daemon/Cargo.toml",
    "start": "./apps/daemon/target/release/favorsd",
    "install:socket": "scripts/install-systemd-user.sh",
    "uninstall:socket": "scripts/uninstall-systemd-user.sh"
  }
}
